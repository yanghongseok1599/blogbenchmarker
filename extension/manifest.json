{
  "manifest_version": 3,
  "name": "BLOG BenchMarker",
  "version": "0.1.0",
  "description": "네이버 블로그 SEO 분석 + AI 글 생성 + 경쟁 블로그 벤치마킹 (Supabase 백엔드)",
  "default_locale": "ko",
  "permissions": [
    "storage",
    "sidePanel",
    "scripting",
    "alarms",
    "notifications",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://blog.naver.com/*",
    "https://*.blog.naver.com/*",
    "https://m.blog.naver.com/*",
    "https://ykyrdwllilffczgryvfv.supabase.co/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "action": {
    "default_title": "BLOG BenchMarker 열기"
  },
  "content_scripts": [
    {
      "matches": [
        "https://blog.naver.com/*",
        "https://*.blog.naver.com/*",
        "https://m.blog.naver.com/*"
      ],
      "js": [
        "content/sidebar-injector.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "mypage/mypage.html",
        "mypage/mypage.js",
        "mypage/mypage.css"
      ],
      "matches": [
        "https://blog.naver.com/*"
      ]
    },
    {
      "resources": [
        "admin/admin.html",
        "admin/admin.js",
        "admin/admin.css"
      ],
      "matches": [
        "https://blog.naver.com/*"
      ]
    },
    {
      "resources": [
        "content/sidebar.html",
        "content/sidebar.js",
        "content/analyzer-bridge.js",
        "content/screenshot-overlay.js",
        "lib/dom-safe.js",
        "lib/supabase-client.js",
        "lib/env-config.js"
      ],
      "matches": [
        "https://blog.naver.com/*",
        "https://*.blog.naver.com/*",
        "https://m.blog.naver.com/*"
      ]
    }
  ]
}
